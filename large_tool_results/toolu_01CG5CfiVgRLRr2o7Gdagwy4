    // =========================================================================
    // NEW ENGAGEMENT MODAL
    // =========================================================================
    function openNewEngagementModal() {
      closeSidebarMobile();
      document.getElementById('new-engagement-modal').classList.remove('hidden');
      document.getElementById('new-engagement-form').reset();
      document.body.style.overflow = 'hidden';
      // Scroll modal to top after DOM update
      setTimeout(function() {
        var scrollables = document.querySelectorAll('#new-engagement-modal .overflow-y-auto, #new-engagement-modal [class*="overflow"]');
        scrollables.forEach(function(el) { el.scrollTop = 0; });
      }, 0);
    }

    function closeNewEngagementModal() {
      document.getElementById('new-engagement-modal').classList.add('hidden');
      document.body.style.overflow = '';
    }

    function handleCreateEngagement(event) {
      event.preventDefault();
      var form = event.target;
      var btn = document.getElementById('btn-create-engagement');
      var spinner = document.getElementById('create-spinner');

      var data = {
        target_company: form.target_company.value.trim(),
        client_name: form.client_name.value.trim(),
        engagement_type: form.engagement_type.value,
        deal_type: form.deal_type.value,
        industry: form.industry.value.trim(),
        estimated_ev: form.enterprise_value.value.trim(),
        deal_timeline_weeks: form.deal_timeline.value ? parseInt(form.deal_timeline.value) : 4,
        engagement_partner: form.engagement_partner.value.trim(),
      };

      if (!data.target_company || !data.client_name) {
        showToast('Please fill in all required fields', 'warning');
        return;
      }

      btn.disabled = true;
      spinner.classList.remove('hidden');

      createEngagement(data).then(function(result) {
        showToast('Engagement created successfully', 'success');
        closeNewEngagementModal();
        var engId = result.engagement_id || result.id || result._id || (result.engagement && (result.engagement.engagement_id || result.engagement.id || result.engagement._id));
        if (engId) {
          navigateTo('engagement', { id: engId });
        } else {
          navigateTo('dashboard');
        }
      }).catch(function(err) {
        showToast('Failed to create engagement: ' + err.message, 'error');
      }).finally(function() {
        btn.disabled = false;
        spinner.classList.add('hidden');
      });
    }

    // =========================================================================
    // ENGAGEMENT DETAIL
    // =========================================================================
    function loadEngagementDetail(id) {
      showLoadingOverlay(true);
      fetchEngagement(id).then(function(eng) {
        state.currentEngagement = eng;
        renderEngagementDetail();
        restartPollingForRunningStages();
      }).catch(function(err) {
        showToast('Failed to load engagement: ' + err.message, 'error');
        navigateTo('dashboard');
      }).finally(function() {
        showLoadingOverlay(false);
      });
    }

    function showLoadingOverlay(show) {
      var overlay = document.getElementById('loading-overlay');
      if (show) {
        overlay.classList.remove('hidden');
        overlay.style.display = 'flex';
      } else {
        overlay.classList.add('hidden');
        overlay.style.display = '';
      }
    }

    function renderEngagementDetail() {
      var eng = state.currentEngagement;
      if (!eng) return;

      function safeSet(id, val) {
        var el = document.getElementById(id);
        if (el) el.textContent = val || 'N/A';
      }

      safeSet('eng-title', getVal(eng, 'target_company', 'targetCompany'));
      safeSet('eng-client', getVal(eng, 'client_name', 'clientName'));
      safeSet('eng-type', getVal(eng, 'engagement_type', 'engagementType'));
      safeSet('eng-deal-type', getVal(eng, 'deal_type', 'dealType'));
      safeSet('eng-industry', eng.industry);
      safeSet('eng-ev', eng.estimated_ev || getVal(eng, 'enterprise_value', 'enterpriseValue'));
      var timeline = eng.deal_timeline_weeks || getVal(eng, 'deal_timeline', 'dealTimeline');
      safeSet('eng-timeline', timeline ? timeline + ' weeks' : 'N/A');
      safeSet('eng-partner', getVal(eng, 'engagement_partner', 'engagementPartner'));
      safeSet('eng-created', formatDate(eng.created_at || eng.createdAt));

      var badge = document.getElementById('eng-status-badge');
      var statusColor = getStatusColor(eng.status);
      badge.className = 'px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider ' + statusColor.bg + ' ' + statusColor.text;
      badge.textContent = eng.status || 'draft';

      var progress = calculateProgress(eng);
      document.getElementById('eng-progress-text').textContent = progress + '%';
      document.getElementById('eng-progress-bar').style.width = progress + '%';

      renderPipelineStages();
    }

    function getStageStatus(stageKey) {
      var eng = state.currentEngagement;
      if (!eng || !eng.stages || !eng.stages[stageKey]) return 'locked';
      return eng.stages[stageKey].status || 'locked';
    }

    function getStageData(stageKey) {
      var eng = state.currentEngagement;
      if (!eng || !eng.stages) return null;
      return eng.stages[stageKey] || null;
    }

    function isStageReady(stageKey) {
      var config = getStageConfig(stageKey);
      if (!config.prerequisites || config.prerequisites.length === 0) return true;
      return config.prerequisites.every(function(prereq) { return getStageStatus(prereq) === 'completed'; });
    }

    function deriveStageVisualStatus(stageKey) {
      var stageData = getStageData(stageKey);
      if (stageData) {
        var status = stageData.status;
        if (status === 'completed' || status === 'running' || status === 'failed') return status;
        if (status === 'ready') return 'ready';
      }
      if (isStageReady(stageKey)) return 'ready';
      return 'locked';
    }

    function renderPipelineStages() {
      var container = document.getElementById('pipeline-stages');
      container.innerHTML = '';

      PHASES.forEach(function(phase) {
        var section = document.createElement('div');
        var isAnalysis = phase.key === 'analysis';

        // Phase header
        var headerDiv = document.createElement('div');
        headerDiv.className = 'flex items-center gap-3 mb-4';
        headerDiv.innerHTML = '<span class="text-2xl">' + phase.icon + '</span>' +
          '<div><h3 class="text-lg font-bold" style="color:' + phase.color + '">' + phase.label + '</h3>' +
          '<p class="text-xs text-kpmg-medium-gray uppercase tracking-wider">' + phase.stages.length + ' stage' + (phase.stages.length > 1 ? 's' : '') + '</p></div>' +
          '<div class="flex-1 h-px" style="background:' + phase.color + '20"></div>';
        section.appendChild(headerDiv);

        // Stage grid
        var gridDiv = document.createElement('div');
        gridDiv.className = isAnalysis ? 'grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4' : 'grid grid-cols-1 md:grid-cols-2 gap-4';

        phase.stages.forEach(function(stageKey) {
          var config = getStageConfig(stageKey);
          var visualStatus = deriveStageVisualStatus(stageKey);
          var stageData = getStageData(stageKey);
          var card = createStageCard(stageKey, config, visualStatus, stageData);
          gridDiv.appendChild(card);
        });

        section.appendChild(gridDiv);
        container.appendChild(section);
      });
    }

