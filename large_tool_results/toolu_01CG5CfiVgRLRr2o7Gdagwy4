          '</div>' +
          statusIndicator +
        '</div>' +
        '<p class="text-xs text-kpmg-medium-gray leading-relaxed mb-3" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">' + escapeAttr(config.description) + '</p>' +
        errorHtml +
        '<div class="flex items-center gap-2">' + actionBtn + '</div>' +
        feedHtml +
