          var delivCount = getDeliverableCount(stageKey);
          statusIndicator = '<div class="flex items-center gap-2 flex-wrap">' +
            '<span class="w-5 h-5 rounded-full bg-kpmg-success flex items-center justify-center"><svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg></span>' +
