            '</div>';
          actionBtn = '<button onclick="event.stopPropagation(); handleCancelStage(\'' + escapeAttr(stageKey) + '\')" class="btn-transition px-3 py-1.5 bg-kpmg-error text-white text-xs font-semibold rounded-lg hover:bg-red-700 shadow-sm">Cancel</button>';
