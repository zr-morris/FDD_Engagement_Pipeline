            '<span class="text-[11px] font-semibold text-kpmg-success uppercase tracking-wider">Output Preview</span>' +
          '</div>' +
          '<p class="text-xs text-kpmg-dark-gray leading-relaxed" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">' + escapeAttr(previewText) + '</p>' +
