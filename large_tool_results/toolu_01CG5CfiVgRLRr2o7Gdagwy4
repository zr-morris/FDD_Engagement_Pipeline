            '<button onclick="event.stopPropagation(); handleExecuteStage(\'' + escapeAttr(stageKey) + '\')" class="btn-transition px-3 py-1.5 bg-white text-kpmg-medium-gray text-xs font-semibold rounded-lg hover:bg-gray-100 border border-gray-300">Re-run</button>';
          break;
        case 'failed':
          bgClass = 'bg-white';
