      var bgClass = '';
      var extraBorder = '';
      var borderColor = '';

      switch (status) {
        case 'locked':
          bgClass = 'bg-gray-100';
          extraBorder = 'border-gray-300';
          statusIndicator = '<span class="text-lg opacity-50">🔒</span>';
