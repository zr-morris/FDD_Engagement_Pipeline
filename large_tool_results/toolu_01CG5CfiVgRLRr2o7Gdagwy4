    // =========================================================================
    // ELAPSED TIMER
    // =========================================================================
    function startElapsedTimer(stageKey, startedAt) {
      if (state.elapsedTimers[stageKey]) clearInterval(state.elapsedTimers[stageKey]);
      if (!startedAt) return;
      var startTime = new Date(startedAt).getTime();
      state.elapsedTimers[stageKey] = setInterval(function() {
        var el = document.getElementById('elapsed-' + stageKey);
        if (el) {
          el.textContent = formatDuration(Date.now() - startTime);
        } else {
          clearInterval(state.elapsedTimers[stageKey]);
          delete state.elapsedTimers[stageKey];
        }
      }, 1000);
    }

    function cleanupElapsedTimers() {
      Object.keys(state.elapsedTimers).forEach(function(key) {
        clearInterval(state.elapsedTimers[key]);
      });
      state.elapsedTimers = {};
    }

    // =========================================================================
    // STAGE EXECUTION & POLLING
    // =========================================================================
    function handleExecuteStage(stageKey) {
      if (!state.currentEngagement) return;
      var engId = state.currentEngagement.engagement_id || state.currentEngagement.id || state.currentEngagement._id;
      var stageName = getStageConfig(stageKey).name;

      showToast('Executing ' + stageName + '...', 'info');

      executeStage(engId, stageKey).then(function(result) {
        if (!state.currentEngagement.stages) state.currentEngagement.stages = {};
        state.currentEngagement.stages[stageKey] = Object.assign(
          state.currentEngagement.stages[stageKey] || {},
          { status: 'running', started_at: new Date().toISOString(), thread_id: result.thread_id || result.threadId }
        );
        renderEngagementDetail();

        var threadId = result.thread_id || result.threadId;
        if (threadId) startPolling(threadId, engId, stageKey);
      }).catch(function(err) {
        showToast('Failed to execute stage: ' + err.message, 'error');
      });
    }

    function handleCancelStage(stageKey) {
      var eng = state.currentEngagement;
      if (!eng) return;
      var stageData = eng.stages && eng.stages[stageKey];
      var threadId = stageData && (stageData.thread_id || stageData.threadId);
      if (!threadId) return;

      stopThread(threadId).then(function() {
        showToast('Stage cancelled', 'info');
        stopPolling(threadId);
        return loadEngagementDetail(eng.engagement_id || eng.id || eng._id);
      }).catch(function(err) {
        showToast('Failed to cancel: ' + err.message, 'error');
      });
    }

    function startPolling(threadId, engId, stageKey) {
      if (state.polling[threadId]) clearInterval(state.polling[threadId]);
      state.polling[threadId] = setInterval(function() {
        pollThread(threadId).then(function(threadData) {
          var threadStatus = threadData.status;

          // Update live activity data on the running stage
          if (threadStatus === 'running' && state.currentView === 'engagement' && state.currentEngagement) {
            var sd = state.currentEngagement.stages && state.currentEngagement.stages[stageKey];
            if (sd) {
              sd._live_msg_count = threadData.num_messages || 0;
              // Build a snippet from the last message
              var lastContent = threadData.last_message_content || '';
              if (lastContent) {
                // Strip markdown syntax for card preview, take last meaningful chunk
                var lines = lastContent.split('\n').filter(function(l) { return l.trim().length > 0; });
                var snippet = lines.slice(-6).join('\n');
                sd._live_snippet = snippet.substring(0, 500);
              }
              sd._live_messages = threadData.messages || [];
              if (threadData.deliverables && threadData.deliverables.length > 0) {
                sd.deliverables = threadData.deliverables;
                sd.deliverable_ids = JSON.stringify(threadData.deliverables);
              }
            }
            // Update just the live feed area without full re-render
            var feedEl = document.getElementById('live-feed-' + stageKey);
            if (feedEl && sd && sd._live_snippet) {
              feedEl.textContent = sd._live_snippet;
            } else if (sd && sd._live_snippet) {
              // Need a full re-render to create the feed element
              renderPipelineStages();
              restartPollingForRunningStages();
            }
            // Update message count badge
            var msgBadge = document.querySelector('#elapsed-' + stageKey);
            if (msgBadge && sd && sd._live_msg_count > 0) {
              var parent = msgBadge.parentElement;
              var existing = parent.querySelector('.msg-count-badge');
              if (!existing) {
                var badge = document.createElement('span');
                badge.className = 'msg-count-badge text-xs bg-kpmg-blue/10 text-kpmg-blue px-1.5 py-0.5 rounded font-medium';
                badge.textContent = sd._live_msg_count + ' msg' + (sd._live_msg_count > 1 ? 's' : '');
                parent.appendChild(badge);
              } else {
                existing.textContent = sd._live_msg_count + ' msg' + (sd._live_msg_count > 1 ? 's' : '');
              }
            }
            // Update the stage panel if it's open for this stage
            if (state.selectedStage === stageKey) {
              updatePanelLiveContent(stageKey, threadData);
            }
          }

          if (threadStatus === 'completed' || threadStatus === 'failed' || threadStatus === 'cancelled') {
            stopPolling(threadId);
            if (state.currentView === 'engagement') {
              fetchEngagement(engId).then(function(freshEng) {
                state.currentEngagement = freshEng;
                renderEngagementDetail();
                restartPollingForRunningStages();
                var stageName = getStageConfig(stageKey).name;
                if (threadStatus === 'completed') {
                  showToast(stageName + ' completed successfully!', 'success');
                } else if (threadStatus === 'failed') {
                  showToast(stageName + ' failed.', 'error');
                } else {
                  showToast(stageName + ' was cancelled.', 'warning');
                }
                // Auto-open panel to show results
                if (threadStatus === 'completed') {
                  setTimeout(function() { openStagePanel(stageKey); }, 500);
                }
              });
