            '<div class="flex items-start justify-between mb-3">' +
              '<div class="min-w-0 flex-1"><h4 class="font-bold text-kpmg-dark-gray truncate">' + name + '</h4><p class="text-sm text-kpmg-medium-gray truncate mt-0.5">' + client + '</p></div>' +
              '<span class="ml-2 px-2 py-0.5 rounded-full text-xs font-semibold flex-shrink-0 ' + statusColor.bg + ' ' + statusColor.text + '">' + escapeAttr(eng.status || 'draft') + '</span>' +
            '</div>' +
