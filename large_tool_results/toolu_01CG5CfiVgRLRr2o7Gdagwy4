      <svg class="w-10 h-10 animate-spin-slow text-kpmg-blue" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
      <p class="text-kpmg-medium-gray text-sm font-medium">Loading...</p>
    </div>
  </div>


  <script>
    // =========================================================================
    // APPLICATION STATE
    // =========================================================================
    const state = {
      currentView: 'dashboard',
      engagements: [],
      currentEngagement: null,
      stageConfig: [],
      selectedStage: null,
      polling: {},
      elapsedTimers: {},
      uploadedFiles: [],
      sidebarOpen: false,
    };

    // =========================================================================
    // CONSTANTS
    // =========================================================================
    const PHASES = [
      { key: 'pursuit', label: 'PURSUIT', color: '#00338D', icon: '🎯', stages: ['stage_0'] },
      { key: 'planning', label: 'PLANNING', color: '#005EB8', icon: '📋', stages: ['stage_1', 'stage_2'] },
      { key: 'analysis', label: 'ANALYSIS', color: '#0091DA', icon: '🔍', stages: ['stage_3a', 'stage_3b', 'stage_3c', 'stage_3d', 'stage_3e', 'stage_3f', 'stage_3g'] },
      { key: 'synthesis', label: 'SYNTHESIS', color: '#F2A900', icon: '🔄', stages: ['stage_4', 'stage_5'] },
      { key: 'delivery', label: 'DELIVERY', color: '#009A44', icon: '📊', stages: ['stage_6', 'stage_7'] },
      { key: 'closeout', label: 'CLOSEOUT', color: '#6D6E71', icon: '✅', stages: ['stage_8'] },
    ];

    const DEFAULT_STAGE_CONFIG = [
      { key: 'stage_0', name: 'Pursuit & Screening', phase: 'pursuit', description: 'Initial target screening, CIM review, and go/no-go assessment.', prerequisites: [], deliverables: ['Target Screening Memo', 'Preliminary Risk Assessment'] },
      { key: 'stage_1', name: 'Engagement Setup & Scoping', phase: 'planning', description: 'Define engagement scope, team structure, and workstream allocation.', prerequisites: ['stage_0'], deliverables: ['Engagement Letter', 'Scope Document', 'Team Allocation'] },
      { key: 'stage_2', name: 'Data Request & Collection', phase: 'planning', description: 'Issue information request list (IRL) and set up data room ingestion.', prerequisites: ['stage_1'], deliverables: ['Information Request List', 'Data Room Index', 'Completeness Tracker'] },
      { key: 'stage_3a', name: 'Quality of Earnings (QoE)', phase: 'analysis', description: 'Analyze reported earnings, identify normalizing adjustments, and determine sustainable EBITDA.', prerequisites: ['stage_2'], deliverables: ['QoE Bridge', 'Adjusted EBITDA Schedule', 'Revenue Analysis'] },
      { key: 'stage_3b', name: 'Revenue Deep-Dive', phase: 'analysis', description: 'Detailed revenue analysis by segment, customer, product, and geography.', prerequisites: ['stage_2'], deliverables: ['Revenue Decomposition', 'Customer Concentration Analysis', 'Cohort Analysis'] },
      { key: 'stage_3c', name: 'Working Capital Analysis', phase: 'analysis', description: 'Analyze net working capital trends, seasonality, and peg calculation.', prerequisites: ['stage_2'], deliverables: ['NWC Bridge', 'NWC Peg Calculation', 'Seasonal Adjustments'] },
      { key: 'stage_3d', name: 'Debt & Debt-Like Items', phase: 'analysis', description: 'Identify and quantify debt, debt-like items, and contingent liabilities.', prerequisites: ['stage_2'], deliverables: ['Debt Schedule', 'Off-Balance Sheet Items', 'Contingent Liability Summary'] },
      { key: 'stage_3e', name: 'CapEx & Cash Flow', phase: 'analysis', description: 'Analyze capital expenditures, maintenance vs growth CapEx, and free cash flow conversion.', prerequisites: ['stage_2'], deliverables: ['CapEx Analysis', 'FCF Bridge', 'Cash Conversion Analysis'] },
      { key: 'stage_3f', name: 'Tax & Structuring', phase: 'analysis', description: 'Review tax positions, exposures, net operating losses, and structuring considerations.', prerequisites: ['stage_2'], deliverables: ['Tax Exposure Summary', 'NOL Schedule', 'Structuring Considerations'] },
      { key: 'stage_3g', name: 'Commercial & Market', phase: 'analysis', description: 'Assess market position, competitive landscape, and commercial sustainability.', prerequisites: ['stage_2'], deliverables: ['Market Assessment', 'Competitive Positioning', 'Commercial Sustainability Report'] },
      { key: 'stage_4', name: 'Findings Integration', phase: 'synthesis', description: 'Integrate findings across workstreams, reconcile cross-references, and build unified view.', prerequisites: ['stage_3a', 'stage_3b', 'stage_3c', 'stage_3d', 'stage_3e', 'stage_3f', 'stage_3g'], deliverables: ['Integrated Findings Memo', 'Cross-Workstream Reconciliation'] },
      { key: 'stage_5', name: 'Risk Assessment & Red Flags', phase: 'synthesis', description: 'Compile risk register, categorize findings, and develop red flag summary.', prerequisites: ['stage_4'], deliverables: ['Risk Register', 'Red Flag Summary', 'Key Findings Matrix'] },
      { key: 'stage_6', name: 'Report Drafting', phase: 'delivery', description: 'Draft FDD report with executive summary, detailed findings, and appendices.', prerequisites: ['stage_5'], deliverables: ['Draft FDD Report', 'Executive Summary', 'Appendices Package'] },
      { key: 'stage_7', name: 'Management Presentation', phase: 'delivery', description: 'Prepare management presentation deck and talking points for client delivery.', prerequisites: ['stage_6'], deliverables: ['Presentation Deck', 'Talking Points', 'Q&A Preparation'] },
      { key: 'stage_8', name: 'Engagement Closeout', phase: 'closeout', description: 'Archive workpapers, complete quality review, and close engagement file.', prerequisites: ['stage_7'], deliverables: ['Archived Workpapers', 'Quality Review Checklist', 'Engagement Close Memo'] },
    ];

    const STAGE_ICONS = {
      stage_0: '🎯', stage_1: '📁', stage_2: '📥',
      stage_3a: '💰', stage_3b: '📈', stage_3c: '🔄',
      stage_3d: '🏦', stage_3e: '💸', stage_3f: '📋',
      stage_3g: '🌐', stage_4: '🧩', stage_5: '⚠️',
      stage_6: '📝', stage_7: '📊', stage_8: '✅',
    };

    // =========================================================================
    // UTILITY FUNCTIONS
    // =========================================================================
    function relativeTime(dateStr) {
      if (!dateStr) return 'N/A';
      const date = new Date(dateStr);
      const now = new Date();
      const seconds = Math.floor((now - date) / 1000);
      if (seconds < 5) return 'just now';
      if (seconds < 60) return seconds + ' seconds ago';
      const minutes = Math.floor(seconds / 60);
      if (minutes < 60) return minutes + (minutes === 1 ? ' minute ago' : ' minutes ago');
      const hours = Math.floor(minutes / 60);
      if (hours < 24) return hours + (hours === 1 ? ' hour ago' : ' hours ago');
      const days = Math.floor(hours / 24);
      if (days < 30) return days + (days === 1 ? ' day ago' : ' days ago');
      const months = Math.floor(days / 30);
      return months + (months === 1 ? ' month ago' : ' months ago');
    }

    function formatDate(dateStr) {
      if (!dateStr) return 'N/A';
      return new Date(dateStr).toLocaleDateString('en-US', {
        year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'
      });
    }

    function formatDuration(ms) {
      if (!ms || ms < 0) return '0s';
      const totalSec = Math.floor(ms / 1000);
      if (totalSec < 60) return totalSec + 's';
      const min = Math.floor(totalSec / 60);
      const sec = totalSec % 60;
      if (min < 60) return min + 'm ' + sec + 's';
      const hr = Math.floor(min / 60);
      const remMin = min % 60;
      return hr + 'h ' + remMin + 'm';
    }

    function escapeAttr(str) {
      if (!str) return '';
      return String(str).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function getVal(obj, snakeKey, camelKey) {
      return obj[snakeKey] || obj[camelKey] || '';
    }

    function renderMarkdown(text) {
      if (!text) return '';
      try {
        if (typeof marked !== 'undefined' && marked.parse) {
          return marked.parse(text, { breaks: true, gfm: true });
        }
      } catch(e) { console.warn('Markdown parse error', e); }
      return '<pre>' + escapeAttr(text) + '</pre>';
    }

    function sanitizeAthenaHtml(html) {
      // Convert Athena's escaped custom tags to standard HTML
      return html
        .replace(/&lt;bold&gt;/g, '<strong>')
        .replace(/&lt;\/bold&gt;/g, '</strong>')
        .replace(/&lt;italic&gt;/g, '<em>')
        .replace(/&lt;\/italic&gt;/g, '</em>')
        .replace(/&lt;underline&gt;/g, '<u>')
        .replace(/&lt;\/underline&gt;/g, '</u>')
        .replace(/&lt;strikethrough&gt;/g, '<del>')
        .replace(/&lt;\/strikethrough&gt;/g, '</del>')
        // Remove Athena data-id attributes for cleaner display
        .replace(/ data-id="[^"]*"/g, '')
        // Style tableWrapper divs
        .replace(/class="tableWrapper"/g, 'class="tableWrapper" style="overflow-x:auto;margin:0.5rem 0;"');
    }

    function truncateText(text, maxLen) {
      if (!text) return '';
      if (text.length <= maxLen) return text;
      return text.substring(0, maxLen) + '...';
    }

    // =========================================================================
    // TOAST NOTIFICATION SYSTEM
    // =========================================================================
    function showToast(message, type) {
      type = type || 'info';
      var container = document.getElementById('toast-container');
      var toast = document.createElement('div');
      var colors = {
        success: 'bg-kpmg-success',
        error: 'bg-kpmg-error',
        info: 'bg-kpmg-blue',
        warning: 'bg-kpmg-warning',
      };
      var icons = {
        success: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>',
        error: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>',
        info: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
        warning: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
      };
      toast.className = 'pointer-events-auto animate-toast-in ' + (colors[type] || colors.info) + ' text-white px-4 py-3 rounded-lg shadow-lg flex items-center gap-3 text-sm font-medium';
      var msgSpan = document.createElement('span');
      msgSpan.className = 'flex-1';
      msgSpan.textContent = message;
      toast.innerHTML = '<span class="flex-shrink-0">' + (icons[type] || icons.info) + '</span>';
      toast.appendChild(msgSpan);
      var closeBtn = document.createElement('button');
      closeBtn.className = 'flex-shrink-0 p-1 hover:bg-white/20 rounded';
      closeBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>';
      closeBtn.onclick = function() { toast.remove(); };
      toast.appendChild(closeBtn);
      container.appendChild(toast);
      setTimeout(function() {
        toast.classList.remove('animate-toast-in');
        toast.classList.add('animate-toast-out');
        setTimeout(function() { toast.remove(); }, 300);
      }, 5000);
    }

    // =========================================================================
    // SIDEBAR
    // =========================================================================
    function toggleSidebar() {
      var sidebar = document.getElementById('sidebar');
      var overlay = document.getElementById('sidebar-overlay');
      state.sidebarOpen = !state.sidebarOpen;
      if (state.sidebarOpen) {
        sidebar.classList.remove('-translate-x-full');
        overlay.classList.remove('hidden');
      } else {
        sidebar.classList.add('-translate-x-full');
        overlay.classList.add('hidden');
      }
    }

    function closeSidebarMobile() {
      if (state.sidebarOpen) toggleSidebar();
    }

    function updateNavHighlight(view) {
      document.querySelectorAll('[data-nav]').forEach(function(el) {
        el.classList.remove('bg-kpmg-sidebar-active', 'text-kpmg-sidebar-text-active', 'font-semibold');
        el.classList.add('text-kpmg-sidebar-text');
      });
      var navKey = view === 'engagement' ? 'engagements-list' : view;
      var active = document.querySelector('[data-nav="' + navKey + '"]');
      if (active) {
        active.classList.add('bg-kpmg-sidebar-active', 'text-kpmg-sidebar-text-active', 'font-semibold');
        active.classList.remove('text-kpmg-sidebar-text');
      }
    }

    // =========================================================================
    // NAVIGATION
    // =========================================================================
    function navigateTo(view, data) {
      if (state.currentView === 'engagement' && view !== 'engagement') {
        cleanupPolling();
        cleanupElapsedTimers();
      }
      state.currentView = view;
      document.querySelectorAll('.view-container').forEach(function(el) { el.classList.add('hidden'); });
      closeSidebarMobile();
      updateNavHighlight(view);

      if (view === 'dashboard') {
        document.getElementById('view-dashboard').classList.remove('hidden');
        loadDashboard();
      } else if (view === 'engagements-list') {
        document.getElementById('view-engagements-list').classList.remove('hidden');
        loadEngagementsList();
      } else if (view === 'engagement') {
        document.getElementById('view-engagement').classList.remove('hidden');
        if (data && data.id) loadEngagementDetail(data.id);
      } else if (view === 'data-room') {
        document.getElementById('view-data-room').classList.remove('hidden');
        loadDataRoom();
      }
    }

    // =========================================================================
    // API FUNCTIONS
    // =========================================================================
    function apiFetch(url, options) {
      options = options || {};
      var headers = Object.assign({ 'Content-Type': 'application/json' }, options.headers || {});
      var fetchOpts = Object.assign({}, options, { headers: headers });
      return fetch(url, fetchOpts).then(function(resp) {
        if (!resp.ok) {
          return resp.json().catch(function() { return { error: resp.statusText }; }).then(function(errData) {
            throw new Error(errData.error || errData.message || 'HTTP ' + resp.status);
          });
        }
        return resp.json();
      }).catch(function(err) {
        if (err.name === 'TypeError' && err.message.indexOf('fetch') !== -1) {
          throw new Error('Network error: Unable to connect to the server');
        }
        throw err;
      });
    }

    function fetchEngagements() { return apiFetch('/api/engagements'); }
    function createEngagement(data) { return apiFetch('/api/engagements', { method: 'POST', body: JSON.stringify(data) }); }
    function fetchEngagement(id) {
      return apiFetch('/api/engagements/' + encodeURIComponent(id)).then(function(eng) {
        if (eng && eng.stages && Array.isArray(eng.stages)) {
          var stagesMap = {};
          eng.stages.forEach(function(s) {
            var key = s.stage_key || s.key;
            var flat = Object.assign({}, s);
            // Flatten latest_run fields into the stage object for easy access
            if (s.latest_run) {
              flat.thread_id = s.latest_run.thread_id || flat.thread_id;
              flat.started_at = s.latest_run.started_at || flat.started_at;
              flat.completed_at = s.latest_run.completed_at || flat.completed_at;
              flat.result = s.latest_run.result_summary || flat.result;
              flat.result_summary = s.latest_run.result_summary || flat.result_summary;
              flat.error = s.latest_run.error_message || flat.error;
              flat.error_message = s.latest_run.error_message || flat.error_message;
              flat.deliverable_ids = s.latest_run.deliverable_ids || flat.deliverable_ids;
            }
            stagesMap[key] = flat;
          });
          eng.stages = stagesMap;
        }
        return eng;
      });
    }
    function updateEngagement(id, data) { return apiFetch('/api/engagements/' + encodeURIComponent(id), { method: 'PATCH', body: JSON.stringify(data) }); }
    function executeStage(engId, stageKey) { return apiFetch('/api/engagements/' + encodeURIComponent(engId) + '/execute/' + encodeURIComponent(stageKey), { method: 'POST' }); }
    function pollThread(threadId) { return apiFetch('/api/threads/' + encodeURIComponent(threadId)); }
    function stopThread(threadId) { return apiFetch('/api/threads/' + encodeURIComponent(threadId) + '/stop', { method: 'POST' }); }
    function fetchStageRuns(engId, stageKey) { return apiFetch('/api/engagements/' + encodeURIComponent(engId) + '/runs/' + encodeURIComponent(stageKey)); }
    function fetchStageConfig() { return apiFetch('/api/config/stages'); }

    // =========================================================================
    // STAGE CONFIG
    // =========================================================================
    function normalizeStageConfig(config) {
      return config.map(function(s) {
        return {
          key: s.stage_key || s.key,
          name: s.stage_name || s.name,
          number: s.stage_number || s.number || '',
          phase: s.phase,
          description: s.stage_description || s.description || '',
          aop_asset_id: s.aop_asset_id || '',
          sort_order: s.sort_order != null ? s.sort_order : 0,
          prerequisites: STAGE_DEPENDENCIES[s.stage_key || s.key] || s.prerequisites || [],
          deliverables: s.deliverables || []
        };
      });
    }

    var STAGE_DEPENDENCIES = {
      stage_0: [],
      stage_1: ['stage_0'],
      stage_2: ['stage_1'],
      stage_3a: ['stage_2'],
      stage_3b: ['stage_2'],
      stage_3c: ['stage_2'],
      stage_3d: ['stage_2'],
      stage_3e: ['stage_2'],
      stage_3f: ['stage_2'],
      stage_3g: ['stage_2'],
      stage_4: ['stage_3a'],
      stage_5: ['stage_4'],
      stage_6: ['stage_5'],
      stage_7: ['stage_6'],
      stage_8: ['stage_7']
    };

    function loadStageConfig() {
      return fetchStageConfig().then(function(config) {
        if (config && Array.isArray(config) && config.length > 0) {
          state.stageConfig = normalizeStageConfig(config);
        } else {
          state.stageConfig = DEFAULT_STAGE_CONFIG;
        }
      }).catch(function() {
        state.stageConfig = DEFAULT_STAGE_CONFIG;
      });
    }

    function getStageConfig(key) {
      var found = state.stageConfig.find(function(s) { return s.key === key; });
      if (!found) found = DEFAULT_STAGE_CONFIG.find(function(s) { return s.key === key; });
      return found || { key: key, name: key, phase: 'unknown', description: '', prerequisites: [], deliverables: [] };
    }

    // =========================================================================
    // DASHBOARD
    // =========================================================================
    function loadDashboard() {
      fetchEngagements().then(function(data) {
        state.engagements = Array.isArray(data) ? data : (data.engagements || []);
      }).catch(function(err) {
        showToast('Failed to load engagements: ' + err.message, 'error');
        state.engagements = [];
      }).finally(function() {
        renderDashboard();
      });
    }

    function renderDashboard() {
      var engs = state.engagements;
      var total = engs.length;
      var active = engs.filter(function(e) { return e.status === 'active' || e.status === 'in_progress'; }).length;
      var completed = engs.filter(function(e) { return e.status === 'completed' || e.status === 'delivered'; }).length;
      var inProgress = engs.filter(function(e) {
        if (!e.stages) return false;
        return Object.values(e.stages).some(function(s) { return s.status === 'running'; });
      }).length;

      document.getElementById('stat-total').textContent = total;
      document.getElementById('stat-active').textContent = active;
      document.getElementById('stat-completed').textContent = completed;
      document.getElementById('stat-progress').textContent = inProgress;

      var listEl = document.getElementById('recent-engagements-list');
      var noMsg = document.getElementById('no-engagements-msg');

      if (engs.length === 0) {
        listEl.innerHTML = '';
        noMsg.classList.remove('hidden');
        return;
      }
      noMsg.classList.add('hidden');
      var recent = engs.slice().sort(function(a, b) {
        return new Date(b.created_at || b.createdAt || 0) - new Date(a.created_at || a.createdAt || 0);
      }).slice(0, 10);

      listEl.innerHTML = recent.map(function(eng) {
        var statusColor = getStatusColor(eng.status);
        var progress = calculateProgress(eng);
        var created = eng.created_at || eng.createdAt;
        var id = eng.engagement_id || eng.id || eng._id;
        var name = escapeAttr(getVal(eng, 'target_company', 'targetCompany') || 'Untitled');
        var client = escapeAttr(getVal(eng, 'client_name', 'clientName'));
        var engType = escapeAttr(getVal(eng, 'engagement_type', 'engagementType'));
        var dealType = escapeAttr(getVal(eng, 'deal_type', 'dealType'));
        return '<div class="px-6 py-4 hover:bg-gray-50 cursor-pointer transition-colors flex items-center gap-4" onclick="navigateTo(\'engagement\', { id: \'' + escapeAttr(id) + '\' })">' +
          '<div class="flex-1 min-w-0">' +
            '<div class="flex items-center gap-2 mb-1">' +
              '<p class="font-semibold text-kpmg-dark-gray truncate">' + name + '</p>' +
              '<span class="px-2 py-0.5 rounded-full text-xs font-semibold ' + statusColor.bg + ' ' + statusColor.text + '">' + escapeAttr(eng.status || 'draft') + '</span>' +
            '</div>' +
            '<p class="text-sm text-kpmg-medium-gray truncate">' + client + ' &middot; ' + engType + ' &middot; ' + dealType + '</p>' +
          '</div>' +
          '<div class="hidden sm:flex flex-col items-end gap-1 flex-shrink-0">' +
            '<div class="w-24 h-1.5 bg-gray-200 rounded-full overflow-hidden"><div class="h-full bg-kpmg-blue rounded-full" style="width:' + progress + '%"></div></div>' +
            '<p class="text-xs text-kpmg-medium-gray">' + progress + '% complete</p>' +
          '</div>' +
          '<div class="hidden md:block text-right flex-shrink-0"><p class="text-xs text-kpmg-medium-gray">' + relativeTime(created) + '</p></div>' +
          '<svg class="w-5 h-5 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>' +
        '</div>';
      }).join('');
    }

    function getStatusColor(status) {
      var map = {
        draft: { bg: 'bg-gray-100', text: 'text-gray-600' },
        active: { bg: 'bg-blue-100', text: 'text-blue-700' },
        in_progress: { bg: 'bg-blue-100', text: 'text-blue-700' },
        completed: { bg: 'bg-green-100', text: 'text-green-700' },
        delivered: { bg: 'bg-green-100', text: 'text-green-700' },
        cancelled: { bg: 'bg-red-100', text: 'text-red-700' },
      };
      return map[status] || map.draft;
    }

    function calculateProgress(eng) {
      if (eng.progress_pct != null) return eng.progress_pct;
      if (!eng || !eng.stages) return 0;
      var stageKeys = Object.keys(eng.stages);
      if (stageKeys.length === 0) return 0;
      var completedCount = stageKeys.filter(function(k) { return eng.stages[k].status === 'completed'; }).length;
      var totalStages = PHASES.reduce(function(sum, p) { return sum + p.stages.length; }, 0);
      return Math.round((completedCount / totalStages) * 100);
    }

    // =========================================================================
    // ENGAGEMENTS LIST
    // =========================================================================
    function loadEngagementsList() {
      fetchEngagements().then(function(data) {
        state.engagements = Array.isArray(data) ? data : (data.engagements || []);
      }).catch(function(err) {
        showToast('Failed to load engagements: ' + err.message, 'error');
        state.engagements = [];
      }).finally(function() {
        renderEngagementsList();
      });
    }

    function renderEngagementsList() {
      var grid = document.getElementById('engagements-grid');
      var noMsg = document.getElementById('no-engagements-grid-msg');
      if (state.engagements.length === 0) {
        grid.innerHTML = '';
        noMsg.classList.remove('hidden');
        return;
      }
      noMsg.classList.add('hidden');
      var sorted = state.engagements.slice().sort(function(a, b) {
        return new Date(b.created_at || b.createdAt || 0) - new Date(a.created_at || a.createdAt || 0);
      });
      grid.innerHTML = sorted.map(function(eng) {
