            '<div class="mb-2 flex items-center justify-between text-xs"><span class="text-kpmg-medium-gray">Progress</span><span class="font-semibold text-kpmg-blue">' + progress + '%</span></div>' +
            '<div class="w-full h-1.5 bg-gray-200 rounded-full overflow-hidden"><div class="h-full bg-gradient-to-r from-kpmg-blue to-kpmg-light rounded-full transition-all" style="width:' + progress + '%"></div></div>' +
          '</div>' +
          '<div class="px-5 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-between text-xs text-kpmg-medium-gray"><span>' + partner + '</span><span>' + relativeTime(created) + '</span></div>' +
