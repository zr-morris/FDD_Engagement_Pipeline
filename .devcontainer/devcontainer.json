{
  "name": "KPMG FDD Pipeline",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.11" }
  },
  "postCreateCommand": "pnpm install && mkdir -p db && node db/seed.cjs && pnpm build && mkdir -p public && cp dist/index.html public/",
  "postStartCommand": "nohup node server.cjs > /tmp/server.log 2>&1 &",
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "FDD Pipeline App",
      "onAutoForward": "openBrowser"
    }
  },
  "remoteEnv": {
    "PORT": "5173"
  }
}
